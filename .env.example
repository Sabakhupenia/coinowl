# Telegram API credentials — get from https://my.telegram.org
# (Telethon requires these even for bots, unlike python-telegram-bot which only needs the token.)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Google Gemini API key — get from https://aistudio.google.com/apikey
# Primary LLM for the agent (handles routing + reply generation in one call).
GEMINI_API_KEY=

# Optional: override the Gemini model. Defaults to gemini-2.5-flash if unset.
# Examples: gemini-2.0-flash, gemini-1.5-pro
GEMINI_MODEL=

# Optional: OpenAI API key — get from https://platform.openai.com/api-keys
# Primary LLM for non-chart questions (price lookups, stats, general chat).
# Gemini is reserved for chart-rendering requests so its quota lasts longer.
# Leave blank to disable OpenAI and route everything to Gemini.
OPENAI_API_KEY=

# Optional: override the OpenAI model. Defaults to gpt-5.4-mini if unset.
# gpt-5.4-mini is OpenAI's recommended mini for tool-calling/subagents (2.5M
# free tokens/day on traffic-share tier). Bigger options: gpt-5.4, gpt-5.
OPENAI_MODEL=

# Optional: Anthropic API key — get from https://console.anthropic.com/settings/keys
# Last-resort fallback LLM when both OpenAI and Gemini fail. Leave blank to skip.
# Note: Anthropic API requires paid credits (no permanent free tier).
ANTHROPIC_API_KEY=

# Optional: CoinGecko demo plan key (free, ~30 req/min). Sign up at
# https://www.coingecko.com/en/api/pricing to bump from the public ~5 req/min.
# Leave blank to use the public free tier.
COINGECKO_API_KEY=
