# Telegram API credentials — get from https://my.telegram.org
# (Telethon requires these even for bots, unlike python-telegram-bot which only needs the token.)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Google Gemini API key — get from https://aistudio.google.com/apikey
# Primary LLM for the agent (handles routing + reply generation in one call).
GEMINI_API_KEY=

# Anthropic API key — get from https://console.anthropic.com/settings/keys
# Fallback LLM used when Gemini errors (rate limit, network, content filter).
ANTHROPIC_API_KEY=

# Optional: CoinGecko demo plan key (free, ~30 req/min). Sign up at
# https://www.coingecko.com/en/api/pricing to bump from the public ~5 req/min.
# Leave blank to use the public free tier.
COINGECKO_API_KEY=
